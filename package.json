{
    "name": "@sunbox/kicad-toolkit",
    "version": "0.2.1",
    "description": "KiCad PCB parsing and deterministic SVG rendering utilities",
    "keywords": [
        "kicad",
        "pcb",
        "eda",
        "electronics",
        "cad",
        "kicad-pcb",
        "kicad_pcb",
        "s-expression",
        "parser",
        "svg",
        "renderer",
        "board",
        "zip",
        "geometry",
        "javascript",
        "esm"
    ],
    "license": "GPL-3.0-or-later",
    "type": "module",
    "main": "./src/index.mjs",
    "exports": {
        ".": "./src/index.mjs",
        "./parser": "./src/parser.mjs",
        "./renderers": "./src/renderers.mjs",
        "./scene3d": "./src/scene3d.mjs",
        "./workers/kicad-parser.worker.mjs": "./src/workers/kicad-parser.worker.mjs",
        "./styles/kicad-renderers.css": "./src/styles/kicad-renderers.css"
    },
    "files": [
        "src",
        "docs/api.md",
        "docs/model-format.md",
        "docs/testing.md",
        "examples",
        "spec",
        "LICENSE",
        "LICENSES",
        "COMMERCIAL-LICENSE.md",
        "CONTRIBUTING.md",
        "NOTICE.md",
        "README.md",
        "AGENTS.md"
    ],
    "scripts": {
        "start": "node examples/server.mjs",
        "test": "node --test",
        "format": "prettier --write .",
        "check:format": "prettier --check ."
    },
    "dependencies": {
        "fflate": "^0.8.2"
    },
    "devDependencies": {
        "prettier": "^3.4.2"
    },
    "engines": {
        "node": ">=20"
    },
    "repository": {
        "type": "git",
        "url": "git+ssh://git@github.com/SunboX/kicad-toolkit.git"
    },
    "bugs": {
        "url": "https://github.com/SunboX/kicad-toolkit/issues"
    },
    "homepage": "https://github.com/SunboX/kicad-toolkit#readme"
}
