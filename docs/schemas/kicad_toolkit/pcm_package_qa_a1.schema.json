{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "kicad-toolkit.pcm-package-qa.a1",
    "title": "KiCad Toolkit Package QA A1",
    "type": "object",
    "required": ["schema", "pass", "summary", "diagnostics"],
    "properties": {
        "schema": {
            "const": "kicad-toolkit.pcm-package-qa.a1"
        },
        "pass": { "type": "boolean" },
        "summary": {
            "type": "object",
            "properties": {
                "metadataPresent": { "type": "boolean" },
                "symbolLibraryCount": { "type": "number" },
                "footprintCount": { "type": "number" },
                "modelEntryCount": { "type": "number" },
                "modelReferenceCount": { "type": "number" },
                "unresolvedModelReferenceCount": { "type": "number" },
                "diagnosticCount": { "type": "number" }
            },
            "additionalProperties": true
        },
        "metadata": {
            "type": ["object", "null"],
            "additionalProperties": true
        },
        "symbolLibraries": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "path": { "type": "string" },
                    "symbolCount": { "type": "number" }
                },
                "additionalProperties": true
            }
        },
        "footprints": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "path": { "type": "string" },
                    "footprintName": { "type": "string" },
                    "modelReferences": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                },
                "additionalProperties": true
            }
        },
        "modelEntries": {
            "type": "array",
            "items": { "type": "string" }
        },
        "diagnostics": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "severity": { "type": "string" },
                    "code": { "type": "string" },
                    "message": { "type": "string" },
                    "path": { "type": "string" },
                    "footprintPath": { "type": "string" },
                    "modelReference": { "type": "string" }
                },
                "additionalProperties": true
            }
        }
    },
    "additionalProperties": true
}
