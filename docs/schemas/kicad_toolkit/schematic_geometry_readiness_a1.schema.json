{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "kicad-toolkit.schematic.geometry-readiness.a1",
    "title": "KiCad Toolkit Schematic Geometry Readiness A1",
    "type": "object",
    "additionalProperties": true,
    "required": ["schema", "summary", "findings", "indexes"],
    "properties": {
        "schema": {
            "const": "kicad-toolkit.schematic.geometry-readiness.a1"
        },
        "summary": {
            "type": "object",
            "properties": {
                "findingCount": { "type": "number" },
                "warningCount": { "type": "number" },
                "infoCount": { "type": "number" },
                "bezierCount": { "type": "number" },
                "longArcCount": { "type": "number" },
                "degenerateArcCount": { "type": "number" },
                "roundedRectangleCount": { "type": "number" },
                "textFrameCount": { "type": "number" },
                "multilineTextFrameCount": { "type": "number" },
                "unusualFillCount": { "type": "number" },
                "unusualStrokeCount": { "type": "number" },
                "unsupportedPinStyleCount": { "type": "number" },
                "pinOutsideBodyCount": { "type": "number" },
                "fieldOutsideBodyCount": { "type": "number" },
                "unknownGraphicCount": { "type": "number" }
            },
            "additionalProperties": true
        },
        "findings": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["key", "severity", "code", "construct", "message"],
                "properties": {
                    "key": { "type": "string" },
                    "severity": { "type": "string" },
                    "code": { "type": "string" },
                    "construct": { "type": "string" },
                    "sourceKey": { "type": "string" },
                    "ownerIndex": { "type": "string" },
                    "bodyBounds": { "$ref": "#/$defs/bounds" },
                    "message": { "type": "string" }
                }
            }
        },
        "indexes": {
            "type": "object",
            "properties": {
                "findingsBySeverity": { "$ref": "#/$defs/keyIndex" },
                "findingsByConstruct": { "$ref": "#/$defs/keyIndex" }
            },
            "additionalProperties": true
        }
    },
    "$defs": {
        "bounds": {
            "type": "object",
            "properties": {
                "minX": { "type": "number" },
                "minY": { "type": "number" },
                "maxX": { "type": "number" },
                "maxY": { "type": "number" },
                "width": { "type": "number" },
                "height": { "type": "number" }
            },
            "additionalProperties": true
        },
        "keyIndex": {
            "type": "object",
            "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
            }
        }
    }
}
