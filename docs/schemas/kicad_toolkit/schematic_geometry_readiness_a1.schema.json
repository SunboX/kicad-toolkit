{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "kicad-toolkit.schematic.geometry-readiness.a1",
    "title": "KiCad Toolkit Schematic Geometry Readiness A1",
    "type": "object",
    "additionalProperties": true,
    "required": ["schema", "summary", "findings", "indexes"],
    "properties": {
        "schema": {
            "const": "kicad-toolkit.schematic.geometry-readiness.a1"
        },
        "summary": {
            "type": "object",
            "additionalProperties": true
        },
        "findings": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": true,
                "required": ["key", "severity", "code", "construct", "message"],
                "properties": {
                    "key": { "type": "string" },
                    "severity": { "type": "string" },
                    "code": { "type": "string" },
                    "construct": { "type": "string" },
                    "sourceKey": { "type": "string" },
                    "message": { "type": "string" }
                }
            }
        },
        "indexes": {
            "type": "object",
            "additionalProperties": true
        }
    }
}
